# Rinku Kirana Shop (myshop) — Environment Variables
# Vercel par deploy karne ke liye:
#   1. Vercel Dashboard > Project > Settings > Environment Variables mein add karo
#   2. SUPABASE_ANON_KEY  → api/chat.js ke liye (server-side)
#   3. SUPABASE_URL       → api/chat.js ke liye (server-side)
#   4. GEMINI_API_KEY     → api/chat.js ke liye (Ananya AI)
#
# Frontend (HTML files) ke liye:
#   index.html aur account.html mein sabse upar ye script add karo:
#   <script>
#     window.__RK_CONFIG__ = {
#       supabaseUrl: "https://pffaflasgwhydkmxwkky.supabase.co",
#       supabaseAnonKey: "sb_publishable__your_key"
#     };
#   </script>
#   (Ye values Vercel Edge Functions ya build script se inject ki ja sakti hain)

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=sb_publishable__your_anon_key_here
GEMINI_API_KEY=your_gemini_api_key_here
